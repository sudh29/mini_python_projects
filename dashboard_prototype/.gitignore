# ═══════════════════════════════════════════════════════════════
# RPA Orchestration Platform — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Frontend (React/Vite) ─────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Backend (Python/FastAPI) ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
ENV/
env/

# uv
.python-version

# SQLite databases (dev only)
*.db
*.sqlite3

# Alembic
alembic/versions/__pycache__/

# ── Worker ────────────────────────────────────────────────────
worker/__pycache__/
worker/bots/**/__pycache__/

# ── Artifacts & Storage ──────────────────────────────────────
artifacts/
screenshots/
*.png
*.jpg
*.jpeg
*.webp
!frontend/public/**/*.png
!frontend/public/**/*.svg

# ── Monitoring ────────────────────────────────────────────────
# Prometheus data
prometheus_data/

# Grafana data (keep dashboard JSONs, ignore runtime data)
grafana_data/

# ── Docker ────────────────────────────────────────────────────
.docker/

# ── Environment & Secrets ────────────────────────────────────
.env
.env.*
!.env.example

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
celery*.log

# ── Editor & IDE ──────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ── Testing & Coverage ───────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
*.swp
*~
